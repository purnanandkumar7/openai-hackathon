      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Total Incidents Resolved (All Time)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(atlas_ai_incidents_resolved_total{namespace=~\"$namespace\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
