          "legendFormat": "P95 — {{agent_name}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(atlas_ai_agent_duration_seconds_bucket{namespace=~\"$namespace\", agent_name=~\"$agent\"}[$__rate_interval])) by (le, agent_name))",
          "legendFormat": "P99 — {{agent_name}}",
