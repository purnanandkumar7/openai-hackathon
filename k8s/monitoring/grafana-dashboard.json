          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(atlas_ai_incidents_resolved_total{namespace=~\"$namespace\"}[1h]))",
          "legendFormat": "Total",
          "refId": "B"
