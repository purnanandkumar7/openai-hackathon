      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(atlas_ai_agent_runs_total{namespace=~\"$namespace\", status=\"success\"}[5m])) by (agent_name) / sum(rate(atlas_ai_agent_runs_total{namespace=~\"$namespace\"}[5m])) by (agent_name)",
          "legendFormat": "{{agent_name}}",
          "refId": "A"
