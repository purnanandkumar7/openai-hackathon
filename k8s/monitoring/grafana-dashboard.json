      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(atlas_ai_incident_resolution_duration_seconds_sum{namespace=~\"$namespace\"}[30m])) by (severity) / sum(rate(atlas_ai_incident_resolution_duration_seconds_count{namespace=~\"$namespace\"}[30m])) by (severity)",
          "legendFormat": "MTTR — {{severity}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
