# =============================================================================
# Atlas AI Backend – Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Lines beginning with # are comments.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Atlas AI
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# HTTP Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Database  (PostgreSQL with pgvector extension)
# -----------------------------------------------------------------------------
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlasdb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false              # Set true to log all SQL queries

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
# Required: your OpenAI API key (sk-...)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o              # Model used for agent reasoning
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2           # Lower = more deterministic (recommended for agents)

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...your-token...
GITHUB_ORG=your-org
GITHUB_REPO=your-org/your-repo   # Default repository (owner/repo format)

# -----------------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------------
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=OPS             # Project where incident tickets are created

# -----------------------------------------------------------------------------
# Slack
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...your-bot-token...
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_INCIDENT_CHANNEL=#incidents  # Channel to post incident alerts

# -----------------------------------------------------------------------------
# Kubernetes
# -----------------------------------------------------------------------------
# kubectl context name. Leave empty to use in-cluster service account.
KUBERNETES_CONTEXT=
KUBERNETES_NAMESPACE=default     # Default namespace for queries
KUBECONFIG_PATH=~/.kube/config   # Path to kubeconfig (ignored when in-cluster)

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_URL=http://prometheus.monitoring.svc.cluster.local:9090

# -----------------------------------------------------------------------------
# Confluence / Documentation
# -----------------------------------------------------------------------------
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_USERNAME=you@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=OPS         # Space to search for runbooks

# -----------------------------------------------------------------------------
# Ceph / Storage Dashboard
# -----------------------------------------------------------------------------
CEPH_DASHBOARD_URL=http://ceph-dashboard.rook-ceph.svc.cluster.local:8080
CEPH_API_USER=admin
CEPH_API_TOKEN=<your-ceph-api-token>

# -----------------------------------------------------------------------------
# OpenTelemetry Tracing
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc:4317
OTEL_SERVICE_NAME=atlas-ai-backend

# -----------------------------------------------------------------------------
# Security / Auth
# -----------------------------------------------------------------------------
# Generate a strong random value: openssl rand -hex 32
SECRET_KEY=<generate-with-openssl-rand-hex-32>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Learning / Vector Search
# -----------------------------------------------------------------------------
# Minimum cosine similarity to retrieve a past incident as "similar"
VECTOR_SIMILARITY_THRESHOLD=0.80
# If true, auto-apply approved resolutions without human confirmation
LEARNING_AUTO_APPLY=false
